<section class="faq section-padding" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    <div class="faq__inner">
      <div class="section-header animate-on-scroll">
        {% if section.settings.title != blank %}
          <h2 class="section-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="section-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>

      <div class="faq__list" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'question' %}
            <div class="faq__item animate-on-scroll" {{ block.shopify_attributes }}>
              <button
                class="faq__question"
                aria-expanded="false"
                aria-controls="faq-answer-{{ forloop.index }}"
              >
                {{ block.settings.question }}
                <svg class="faq__chevron" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
              <div class="faq__answer" id="faq-answer-{{ forloop.index }}" hidden>
                <div class="faq__answer-inner rte">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.contact_text != blank %}
        <div class="faq__contact animate-on-scroll">
          <p>{{ section.settings.contact_text }}
            {% if section.settings.contact_label != blank %}
              <a href="{{ section.settings.contact_url }}" class="faq__contact-link">{{ section.settings.contact_label }}</a>
            {% endif %}
          </p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Everything you need to know before you buy."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F8F8F8"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact prompt text",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact link label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact link URL"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer a 30-day hassle-free return policy. If you're not completely satisfied with your purchase, simply contact us within 30 days for a full refund or exchange.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day hassle-free return policy. If you're not completely satisfied, contact us within 30 days for a full refund.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Standard shipping takes 3-7 business days. Express shipping (1-2 business days) is available at checkout. Free shipping on orders over $75.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Is my payment information secure?",
            "answer": "<p>Absolutely. All transactions are encrypted with 256-bit SSL and processed through Shopify's secure payment gateway. We never store your card details.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "<p>Yes! We ship to over 50 countries worldwide. International shipping rates and delivery times are calculated at checkout.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How do I track my order?",
            "answer": "<p>Once your order ships, you'll receive an email with a tracking number. You can also track your order from your account dashboard.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
