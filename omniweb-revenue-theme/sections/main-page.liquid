<article class="page-content section-padding">
  <div class="page-width page-width--content">
    {% if page.image %}
      <div class="page-content__image">
        <img
          src="{{ page.image | image_url: width: 1200 }}"
          alt="{{ page.image.alt | escape }}"
          class="page-content__hero-image"
          loading="eager"
          width="{{ page.image.width }}"
          height="{{ page.image.height }}"
        >
      </div>
    {% endif %}

    <div class="page-content__header">
      <h1 class="page-content__title">{{ page.title }}</h1>
    </div>

    <div class="page-content__body rte">
      {{ page.content }}
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Page content",
  "settings": []
}
{% endschema %}
