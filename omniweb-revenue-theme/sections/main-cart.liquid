{% if cart.item_count > 0 %}
  <div class="cart-page section-padding">
    <div class="page-width">
      <h1 class="cart-page__title">{{ 'sections.cart.title' | t }}</h1>

      <div class="cart-page__grid">
        <div class="cart-page__items">
          {% for item in cart.items %}
            <div class="cart-item" data-cart-item="{{ item.key }}">
              <div class="cart-item__media">
                {% if item.image %}
                  <img
                    src="{{ item.image | image_url: width: 200 }}"
                    alt="{{ item.image.alt | escape }}"
                    class="cart-item__image"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                {% endif %}
              </div>

              <div class="cart-item__details">
                <div class="cart-item__info">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  {% unless item.product.has_only_default_variant %}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {% endunless %}
                  {% if item.selling_plan_allocation %}
                    <p class="cart-item__selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                  {% endif %}
                  {% if item.properties.size > 0 %}
                    {% for p in item.properties %}
                      {% if p.last != blank %}
                        <p class="cart-item__property"><small>{{ p.first }}: {{ p.last }}</small></p>
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                </div>

                <div class="cart-item__controls">
                  <div class="quantity-selector quantity-selector--sm">
                    <button
                      type="button"
                      class="quantity-selector__btn js-cart-qty"
                      data-key="{{ item.key }}"
                      data-action="decrease"
                      aria-label="Decrease quantity"
                    >−</button>
                    <input
                      type="number"
                      value="{{ item.quantity }}"
                      min="0"
                      class="quantity-selector__input js-cart-qty-input"
                      data-key="{{ item.key }}"
                      aria-label="Quantity"
                    >
                    <button
                      type="button"
                      class="quantity-selector__btn js-cart-qty"
                      data-key="{{ item.key }}"
                      data-action="increase"
                      aria-label="Increase quantity"
                    >+</button>
                  </div>

                  <div class="cart-item__price-group">
                    {% if item.original_price != item.final_price %}
                      <s class="cart-item__original-price">{{ item.original_price | money }}</s>
                    {% endif %}
                    <span class="cart-item__price">{{ item.final_price | money }}</span>
                  </div>

                  <button
                    type="button"
                    class="cart-item__remove js-cart-remove"
                    data-key="{{ item.key }}"
                    aria-label="{{ 'sections.cart.remove' | t }}"
                  >
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M18 6 6 18M6 6l12 12"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="cart-page__summary">
          <div class="cart-summary">
            <h2 class="cart-summary__title">Order Summary</h2>

            <div class="cart-summary__line">
              <span>Subtotal</span>
              <span id="cart-subtotal">{{ cart.total_price | money }}</span>
            </div>

            {% if cart.cart_level_discount_applications.size > 0 %}
              {% for discount in cart.cart_level_discount_applications %}
                <div class="cart-summary__line cart-summary__line--discount">
                  <span>{{ discount.title }}</span>
                  <span>-{{ discount.total_allocated_amount | money }}</span>
                </div>
              {% endfor %}
            {% endif %}

            <div class="cart-summary__shipping-note">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="1" y="3" width="15" height="13" rx="1"/>
                <path d="M16 8h4l3 4v4h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
              {{ 'sections.cart.taxes' | t }}
            </div>

            <a href="{{ routes.checkout }}" class="btn btn--primary btn--full btn--large cart-summary__checkout">
              {{ 'sections.cart.checkout' | t }} &middot; {{ cart.total_price | money }}
            </a>

            <a href="{{ routes.all_products_collection_url }}" class="cart-summary__continue-link">
              ← {{ 'sections.cart.continue_shopping' | t }}
            </a>

            <div class="cart-summary__payment-icons">
              {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'cart-summary__payment-icon' }}
            </div>
          </div>

          {% if settings.enable_cart_upsell and settings.cart_upsell_collection != blank %}
            <div class="cart-upsell">
              <h3 class="cart-upsell__title">{{ settings.cart_upsell_title }}</h3>
              {% assign upsell_products = settings.cart_upsell_collection.products | limit: 3 %}
              <div class="cart-upsell__grid">
                {% for product in upsell_products %}
                  {% render 'product-card-mini', product: product %}
                {% endfor %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% else %}
  <div class="cart-empty section-padding">
    <div class="page-width cart-empty__inner">
      <svg class="cart-empty__icon" viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <h1 class="cart-empty__title">{{ 'sections.cart.empty' | t }}</h1>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary btn--large">
        {{ 'sections.cart.continue_shopping' | t }}
      </a>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Cart page",
  "settings": []
}
{% endschema %}
