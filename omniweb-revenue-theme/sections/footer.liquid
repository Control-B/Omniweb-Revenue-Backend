<footer class="footer">
  <div class="footer__top page-width">
    <div class="footer__grid">
      <div class="footer__col footer__col--brand">
        {% if settings.logo != blank %}
          <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="footer__logo" width="160" height="auto">
        {% else %}
          <span class="footer__brand-name">{{ shop.name }}</span>
        {% endif %}
        {% if section.settings.tagline != blank %}
          <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {% endif %}

        <div class="footer__social">
          {% if settings.social_instagram != blank %}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer__social-link">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          {% endif %}
          {% if settings.social_facebook != blank %}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook" class="footer__social-link">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok" class="footer__social-link">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.29 6.29 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.77 1.52V6.75a4.85 4.85 0 01-1-.06z"/>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'menu' %}
          <div class="footer__col" {{ block.shopify_attributes }}>
            {% if block.settings.title != blank %}
              <h3 class="footer__col-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.menu != blank %}
              <ul class="footer__menu list-unstyled" role="list">
                {% for link in block.settings.menu.links %}
                  <li><a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% elsif block.type == 'text' %}
          <div class="footer__col" {{ block.shopify_attributes }}>
            {% if block.settings.title != blank %}
              <h3 class="footer__col-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="footer__text rte">{{ block.settings.text }}</div>
            {% endif %}
          </div>
        {% elsif block.type == 'newsletter' %}
          <div class="footer__col" {{ block.shopify_attributes }}>
            {% if block.settings.title != blank %}
              <h3 class="footer__col-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="footer__newsletter-text">{{ block.settings.text }}</p>
            {% endif %}
            {% form 'customer', class: 'footer__newsletter-form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="footer__newsletter-input-wrap">
                <input
                  type="email"
                  name="contact[email]"
                  placeholder="{{ block.settings.placeholder | default: 'Enter your email' }}"
                  required
                  class="footer__newsletter-input"
                  aria-label="Email address"
                >
                <button type="submit" class="btn btn--primary footer__newsletter-btn">
                  {{ block.settings.button_label | default: 'Subscribe' }}
                </button>
              </div>
              {% if form.posted_successfully? %}
                <p class="footer__newsletter-success">Thank you for subscribing!</p>
              {% endif %}
            {% endform %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="footer__bottom">
    <div class="page-width footer__bottom-inner">
      <p class="footer__copyright">{{ 'sections.footer.copyright' | t: year: 'now' | date: '%Y', shop_name: shop.name }}</p>
      <div class="footer__payments">
        {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'footer__payment-icon' }}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Quality products, exceptional service."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Content"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Stay in the loop"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Subtext",
          "default": "Get exclusive deals and early access to new products."
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Input placeholder",
          "default": "Your email address"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Subscribe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu" },
        { "type": "menu" },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
