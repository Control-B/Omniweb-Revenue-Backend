<div class="search-page section-padding">
  <div class="page-width">
    <h1 class="search-page__title">
      {% if search.performed %}
        {% if search.results_count == 0 %}
          No results for &ldquo;{{ search.terms | escape }}&rdquo;
        {% else %}
          {{ search.results_count }} results for &ldquo;{{ search.terms | escape }}&rdquo;
        {% endif %}
      {% else %}
        Search
      {% endif %}
    </h1>

    <form action="{{ routes.search_url }}" method="get" class="search-page__form" role="search">
      <input type="hidden" name="type" value="product">
      <div class="search-page__input-wrap">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search products..."
          class="search-page__input input"
          aria-label="Search"
          autocomplete="off"
        >
        <button type="submit" class="btn btn--primary">Search</button>
      </div>
    </form>

    {% if search.performed %}
      {% if search.results.size > 0 %}
        {% paginate search.results by 24 %}
          <div class="product-grid product-grid--4-col">
            {% for result in search.results %}
              {% if result.object_type == 'product' %}
                {% render 'product-card', product: result %}
              {% else %}
                <div class="search-result">
                  <a href="{{ result.url }}" class="search-result__link">
                    <h3 class="search-result__title">{{ result.title }}</h3>
                    {% if result.body != blank %}
                      <p class="search-result__excerpt">{{ result.body | strip_html | truncate: 100 }}</p>
                    {% endif %}
                  </a>
                </div>
              {% endif %}
            {% endfor %}
          </div>
          {% if paginate.pages > 1 %}
            <div class="search-page__pagination">
              {{ paginate | default_pagination }}
            </div>
          {% endif %}
        {% endpaginate %}
      {% else %}
        <p class="search-page__no-results">{{ 'general.search.no_results_html' | t: terms: search.terms }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Browse All Products</a>
      {% endif %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Search results",
  "settings": []
}
{% endschema %}
