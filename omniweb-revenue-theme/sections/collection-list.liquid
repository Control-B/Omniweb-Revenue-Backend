<section class="collection-list section-padding">
  <div class="page-width">
    <div class="section-header animate-on-scroll">
      {% if section.settings.title != blank %}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {% endif %}
    </div>
    <div class="collection-list__grid collection-list__grid--{{ section.settings.columns }}">
      {% for block in section.blocks %}
        {% if block.type == 'collection' %}
          {% assign collection = block.settings.collection %}
          <div class="collection-card animate-on-scroll" {{ block.shopify_attributes }}>
            <a href="{{ collection.url | default: '#' }}" class="collection-card__link">
              <div class="collection-card__image-wrap">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | default: collection.title }}" class="collection-card__image" loading="lazy" width="800" height="600">
                {% elsif collection != blank and collection.image != blank %}
                  <img src="{{ collection.image | image_url: width: 800 }}" alt="{{ collection.title }}" class="collection-card__image" loading="lazy" width="800" height="600">
                {% else %}
                  <div class="collection-card__image collection-card__image--placeholder"></div>
                {% endif %}
                <div class="collection-card__overlay"></div>
              </div>
              <div class="collection-card__content">
                <h3 class="collection-card__title">{{ block.settings.title | default: collection.title }}</h3>
                {% if block.settings.subtitle != blank %}
                  <p class="collection-card__subtitle">{{ block.settings.subtitle }}</p>
                {% endif %}
                <span class="collection-card__cta btn btn--outline-white">Shop Now</span>
              </div>
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image (overrides collection image)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title (overrides collection title)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
