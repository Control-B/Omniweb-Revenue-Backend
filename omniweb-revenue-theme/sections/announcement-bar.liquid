{% if section.settings.show_announcement %}
<div class="announcement-bar" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="announcement-bar__inner page-width">
    {% if section.settings.announcement_text != blank %}
      <p class="announcement-bar__text">
        {% if section.settings.announcement_link != blank %}
          <a href="{{ section.settings.announcement_link }}" class="announcement-bar__link">
            {{ section.settings.announcement_text }}
          </a>
        {% else %}
          {{ section.settings.announcement_text }}
        {% endif %}
      </p>
    {% endif %}
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "limit": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Free shipping on orders over $75 · Use code FREESHIP"
    },
    {
      "type": "url",
      "id": "announcement_link",
      "label": "Announcement link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
