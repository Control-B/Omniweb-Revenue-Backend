<section class="newsletter section-padding" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    <div class="newsletter__inner">
      {% if section.settings.icon_emoji != blank %}
        <div class="newsletter__icon">{{ section.settings.icon_emoji }}</div>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="newsletter__title" style="color: {{ section.settings.text_color }};">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="newsletter__subtitle" style="color: {{ section.settings.text_color }};">{{ section.settings.subtitle }}</p>
      {% endif %}
      {% form 'customer', class: 'newsletter__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter__form-row">
          <input
            type="email"
            name="contact[email]"
            class="newsletter__input"
            placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
            required
            aria-label="Email address"
            autocomplete="email"
          >
          <button type="submit" class="btn btn--primary newsletter__btn">
            {{ section.settings.button_label | default: 'Subscribe' }}
          </button>
        </div>
        {% if form.posted_successfully? %}
          <p class="newsletter__success">{{ section.settings.success_message | default: "Thanks for subscribing!" }}</p>
        {% endif %}
        {% if section.settings.privacy_text != blank %}
          <p class="newsletter__privacy" style="color: {{ section.settings.text_color }};">{{ section.settings.privacy_text }}</p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "icon_emoji",
      "label": "Icon emoji",
      "default": "📬"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Get 10% Off Your First Order"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Join our community and be first to hear about new drops, exclusive deals, and more."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get 10% Off"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in! Check your inbox for your discount code."
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy notice",
      "default": "No spam, ever. Unsubscribe at any time."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
