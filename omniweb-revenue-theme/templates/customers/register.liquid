<div class="account-page section-padding">
  <div class="page-width page-width--narrow">
    <h1 class="account-page__title">Create Account</h1>

    {% form 'create_customer' %}
      {% if form.errors %}
        <div class="form-error" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="form-group form-group--half">
        <div>
          <label for="first-name">First Name</label>
          <input type="text" id="first-name" name="customer[first_name]" autocomplete="given-name" class="input">
        </div>
        <div>
          <label for="last-name">Last Name</label>
          <input type="text" id="last-name" name="customer[last_name]" autocomplete="family-name" class="input">
        </div>
      </div>

      <div class="form-group">
        <label for="reg-email">Email</label>
        <input type="email" id="reg-email" name="customer[email]" autocomplete="email" class="input" required>
      </div>

      <div class="form-group">
        <label for="reg-password">Password</label>
        <input type="password" id="reg-password" name="customer[password]" autocomplete="new-password" class="input" required>
      </div>

      <button type="submit" class="btn btn--primary btn--full">Create Account</button>
    {% endform %}

    <div class="account-page__alt">
      <p>Already have an account? <a href="{{ routes.account_login_url }}">Sign in</a></p>
    </div>
  </div>
</div>
