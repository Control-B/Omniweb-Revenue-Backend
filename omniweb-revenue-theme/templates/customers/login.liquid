<div class="account-page section-padding">
  <div class="page-width page-width--narrow">
    <h1 class="account-page__title">Sign In</h1>

    {% form 'customer_login' %}
      {% if form.errors %}
        <div class="form-error" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="form-group">
        <label for="customer-email">Email</label>
        <input
          type="email"
          id="customer-email"
          name="customer[email]"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          class="input"
          required
        >
      </div>

      <div class="form-group">
        <label for="customer-password">Password</label>
        <input
          type="password"
          id="customer-password"
          name="customer[password]"
          autocomplete="current-password"
          class="input"
          required
        >
      </div>

      <button type="submit" class="btn btn--primary btn--full">Sign In</button>
      <a href="{{ routes.root_url }}account/recover" class="account-page__recover-link">Forgot your password?</a>
    {% endform %}

    <div class="account-page__alt">
      <p>Don't have an account? <a href="{{ routes.account_register_url }}">Create one</a></p>
    </div>
  </div>
</div>
