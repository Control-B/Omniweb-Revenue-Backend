{% comment %}
  Mini product card for cart upsell
  Usage: {% render 'product-card-mini', product: product %}
{% endcomment %}

<div class="product-card-mini">
  <a href="{{ product.url }}" class="product-card-mini__image-link">
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 160 }}"
        alt="{{ product.featured_image.alt | escape | default: product.title }}"
        class="product-card-mini__image"
        loading="lazy"
        width="80"
        height="80"
      >
    {% else %}
      <div class="product-card-mini__image product-card-mini__image--placeholder">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </a>
  <div class="product-card-mini__info">
    <a href="{{ product.url }}" class="product-card-mini__title">{{ product.title }}</a>
    <p class="product-card-mini__price">{{ product.price | money }}</p>
    <button
      type="button"
      class="btn btn--primary btn--sm product-card-mini__atc js-product-card-atc"
      data-variant-id="{{ product.first_available_variant.id }}"
      {% unless product.first_available_variant.available %}disabled{% endunless %}
    >
      Add
    </button>
  </div>
</div>
