{% comment %}
  Renders a star rating
  Usage: {% render 'stars', rating: 4.5 %}
{% endcomment %}

{% assign rating_int = rating | floor %}
{% assign rating_frac = rating | minus: rating_int %}
<div class="stars" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating, rating_max: 5 }}" role="img">
  {% for i in (1..5) %}
    {% if i <= rating_int %}
      <svg class="star star--full" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
        <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2"/>
      </svg>
    {% elsif i == rating_int | plus: 1 and rating_frac >= 0.5 %}
      <svg class="star star--half" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
        <defs>
          <linearGradient id="half-{{ forloop.index }}">
            <stop offset="50%" stop-color="currentColor"/>
            <stop offset="50%" stop-color="transparent"/>
          </linearGradient>
        </defs>
        <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" fill="url(#half-{{ forloop.index }})" stroke="currentColor" stroke-width="1"/>
      </svg>
    {% else %}
      <svg class="star star--empty" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2"/>
      </svg>
    {% endif %}
  {% endfor %}
</div>
