{% comment %}
  Omniweb AI Sales Widget Snippet
  ---------------------------------
  Outputs the page-context data object and loads the AI chat widget.
  All data comes from Shopify storefront globals — no Admin API required.

  Usage in theme.liquid:
    {% render 'ai-widget' %}

  Configure in Theme Editor → Theme Settings → AI Sales Widget.
{% endcomment %}

{% if settings.enable_ai_widget and settings.widget_api_url != blank and settings.widget_api_key != blank %}

  {%- liquid
    assign _currency = cart.currency.iso_code
    assign _locale   = request.locale.iso_code
    assign _page     = template.name
  -%}

  <script>
    /* Omniweb page context — read by the AI widget on each chat message */
    window.__owContext = (function () {
      var ctx = {
        pageType:  {{ _page | json }},
        shopName:  {{ shop.name | json }},
        currency:  {{ _currency | json }},
        locale:    {{ _locale | json }},
        pageUrl:   window.location.href
      };

      {% comment %}── Product page ──{% endcomment %}
      {% if _page == 'product' %}
        ctx.product = {
          id:             {{ product.id | json }},
          title:          {{ product.title | json }},
          vendor:         {{ product.vendor | json }},
          type:           {{ product.type | json }},
          handle:         {{ product.handle | json }},
          url:            {{ product.url | prepend: shop.url | json }},
          description:    {{ product.description | strip_html | truncate: 600 | json }},
          price:          {{ product.price | money_without_currency | json }},
          compareAtPrice: {{ product.compare_at_price | money_without_currency | json }},
          available:      {{ product.available | json }},
          tags:           {{ product.tags | json }},
          variantDetails: [
            {%- for v in product.variants -%}
              {
                "id":        {{ v.id }},
                "title":     {{ v.title | json }},
                "price":     {{ v.price | money_without_currency | json }},
                "available": {{ v.available }},
                "sku":       {{ v.sku | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        };
        {% if product.collections.first.handle %}
          ctx.collectionHandle = {{ product.collections.first.handle | json }};
          ctx.collectionTitle  = {{ product.collections.first.title | json }};
        {% endif %}
      {% endif %}

      {% comment %}── Collection page ──{% endcomment %}
      {% if _page == 'collection' %}
        ctx.collection = {
          title:         {{ collection.title | json }},
          handle:        {{ collection.handle | json }},
          description:   {{ collection.description | strip_html | truncate: 400 | json }},
          productsCount: {{ collection.products_count | json }},
          products: [
            {%- for p in collection.products limit: 10 -%}
              {
                "title":     {{ p.title | json }},
                "price":     {{ p.price | money_without_currency | json }},
                "available": {{ p.available }},
                "handle":    {{ p.handle | json }},
                "url":       {{ p.url | prepend: shop.url | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        };
      {% endif %}

      {% comment %}── Cart page ──{% endcomment %}
      {% if _page == 'cart' %}
        ctx.cart = {
          itemCount:  {{ cart.item_count | json }},
          totalPrice: {{ cart.total_price | money | json }},
          items: [
            {%- for item in cart.items -%}
              {
                "title":        {{ item.title | json }},
                "variantTitle": {{ item.variant.title | json }},
                "quantity":     {{ item.quantity }},
                "linePrice":    {{ item.line_price | money | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        };
      {% endif %}

      {% comment %}── Search page ──{% endcomment %}
      {% if _page == 'search' %}
        ctx.searchTerm = {{ search.terms | json }};
        ctx.searchResultCount = {{ search.results_count | json }};
      {% endif %}

      return ctx;
    })();
  </script>

  <script
    src="{{ settings.widget_api_url }}/widget.js"
    data-api-url="{{ settings.widget_api_url }}"
    data-api-key="{{ settings.widget_api_key }}"
    data-shop-id="{{ shop.permanent_domain }}"
    defer
  ></script>

{% endif %}
